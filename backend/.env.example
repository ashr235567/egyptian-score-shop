NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/egyptian-score-shop

# JWT
JWT_SECRET=egyptianscoreshop
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# Client
CLIENT_URL=http://localhost:5173

# Admin seed account
ADMIN_EMAIL=admin@egyptianscoreshop.com
ADMIN_PASSWORD=Admin@12345

# Email (Nodemailer - e.g. Gmail App Password or SMTP provider like SendGrid/Mailtrap)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
EMAIL_FROM=noreply@egyptianscoreshop.com

# WhatsApp business number (international format, no + or spaces) used for order checkout redirects
WHATSAPP_NUMBER=201234567890
