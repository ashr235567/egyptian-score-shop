# The frontend talks to the backend via the /api proxy configured in vite.config.js
# during development. In production, deploy the backend and point your hosting
# provider's reverse proxy (e.g. Nginx) at it, or set an absolute API URL below
# and update src/api/axios.js baseURL accordingly.

VITE_API_URL=http://localhost:5000/api

# WhatsApp number used for general contact links (floating button, footer, product
# inquiry link). International format, digits only, no + or spaces.
# Keep this in sync with WHATSAPP_NUMBER in backend/.env, which is the source of
# truth for the actual order checkout message.
VITE_WHATSAPP_NUMBER=201234567890
